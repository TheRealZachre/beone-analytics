# Copy to .dev.vars for local OpenNext/Wrangler preview (do not commit .dev.vars)
NEXTJS_ENV=development

# =============================================================================
# Fastest fix (one command, after wrangler login):
#   npx wrangler login
#   npm run setup:cloudflare
# =============================================================================

# =============================================================================
# Cloudflare Workers Builds — recommended dashboard settings
# =============================================================================
# Build command:  npm run build:cloudflare
# Deploy command: npx wrangler deploy
#
# Use build:cloudflare (OpenNext), not npm run build (Next.js only).
# OpenNext calls npm run build internally; pointing build at OpenNext loops forever.
#
# Add AUTH_SECRET under Worker → Settings → Variables and Secrets.
#
# Alternative (build + deploy in one step):
#   Build command:  npm run ci:cloudflare
#   Deploy command: echo "deployed in build step"

# AUTH_SECRET=
# AUTH_URL=https://your-worker.workers.dev

# Optional API keys
# OPENAI_API_KEY=
# TRANSCRIPTION_PROVIDER=openai
